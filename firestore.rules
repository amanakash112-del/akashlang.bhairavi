rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Words: anyone can read; signed-in users can create; no updates or deletes
    match /words/{wordId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Sentences: same rules as words
    match /sentences/{sentenceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // All other collections: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
