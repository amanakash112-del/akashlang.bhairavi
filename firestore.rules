rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Words: anyone can read; signed-in users can create; only developer can promote (update)
    match /words/{wordId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.email == 'aman.akash112@gmail.com';
      allow delete: if false;
    }
    // Sentences: same rules as words
    match /sentences/{sentenceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.email == 'aman.akash112@gmail.com';
      allow delete: if false;
    }
    // Phrases: public read; developer-only write
    match /phrases/{phraseId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'aman.akash112@gmail.com';
    }
    // Clauses: public read; developer-only write
    match /clauses/{clauseId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'aman.akash112@gmail.com';
    }
    // All other collections: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
